# Use either Google AI Studio key or Vertex AI configuration supported by ADK.
GOOGLE_API_KEY="YOUR_API_KEY"

# Default Gemini model used by the root ADK agent.
ADK_MODEL="gemini-flash-latest"

# Logical ADK app/user defaults for local smoke runs.
ADK_APP_NAME="adk-agent-orchestrator"
ADK_USER_ID="local-user"

# Phase 3 local tool timeout in seconds.
ADK_TOOL_TIMEOUT_SECONDS="10"

# Optional MCP servers as JSON. Example:
# ADK_MCP_SERVERS='[{"name":"filesystem","transport":"stdio","command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","."]}]'
ADK_MCP_SERVERS="[]"
